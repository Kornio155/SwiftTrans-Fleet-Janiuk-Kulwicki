<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FleetManager.ViewModels"
        xmlns:global="clr-namespace:"
        x:DataType="global:EditVehicleViewModel"
        x:Class="FleetManager.Views.EditVehicleWindow"
        Width="300"
        Height="300"
        Title="Edytuj pojazd">

    <StackPanel Margin="10" Spacing="5">
        <TextBox Text="{Binding Marka}"/>
        <TextBox Text="{Binding Model}"/>
        <TextBox Text="{Binding RokProdukcji}"/>
        <TextBox Text="{Binding IloscPaliwa}"/>
        <ComboBox ItemsSource="{Binding Status}"
                  SelectedItem="{Binding StatusPojazdu}"/>


        <Button Content="Zapisz" Command="{Binding SaveCommand}"/>
    </StackPanel>
</Window>